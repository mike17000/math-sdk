"""Game-specific configuration file for Olympus Rising."""

import os
from src.config.config import Config
from src.config.distributions import Distribution
from src.config.betmode import BetMode


class GameConfig(Config):

    _instance = None

    def __new__(cls):
        if cls._instance is None:
            cls._instance = super().__new__(cls)
        return cls._instance

    def __init__(self):
        super().__init__()
        self.game_id = "olympus_rising"
        self.provider_number = 0
        self.working_name = "Olympus Rising"
        self.wincap = 5000.0
        self.win_type = "lines"
        self.rtp = 0.9600  # Target 96.0%
        self.construct_paths()

        # Game Dimensions
        self.num_reels = 5
        self.num_rows = [3] * self.num_reels
        
        # Board and Symbol Properties
        # Paytable: (count, symbol): multiplier
        # Converted from basis points (divide by 100)
        self.paytable = {
            # Wild (W) - highest value
            (5, "W"): 50,
            (4, "W"): 20,
            (3, "W"): 10,
            
            # Zeus (H1) - premium
            (5, "H1"): 25,
            (4, "H1"): 10,
            (3, "H1"): 5,
            
            # Hera (H2) - high
            (5, "H2"): 15,
            (4, "H2"): 5,
            (3, "H2"): 3,
            
            # Poseidon (H3) - high
            (5, "H3"): 10,
            (4, "H3"): 3,
            (3, "H3"): 2,
            
            # Athena (H4) - high
            (5, "H4"): 8,
            (4, "H4"): 2,
            (3, "H4"): 1,
            
            # Golden Coin (L1) - low
            (5, "L1"): 5,
            (4, "L1"): 1,
            (3, "L1"): 0.5,
            
            # Amphora (L2) - low
            (5, "L2"): 3,
            (4, "L2"): 0.7,
            (3, "L2"): 0.3,
            
            # Laurel Wreath (L3) - low
            (5, "L3"): 3,
            (4, "L3"): 0.7,
            (3, "L3"): 0.3,
        }

        # Paylines - 20 standard patterns (0-indexed rows)
        self.paylines = {
            1: [1, 1, 1, 1, 1],  # Middle line
            2: [0, 0, 0, 0, 0],  # Top line
            3: [2, 2, 2, 2, 2],  # Bottom line
            4: [0, 1, 2, 1, 0],  # V shape
            5: [2, 1, 0, 1, 2],  # Inverted V
            6: [0, 0, 1, 2, 2],  # Descending
            7: [2, 2, 1, 0, 0],  # Ascending
            8: [1, 0, 1, 2, 1],  # W shape
            9: [1, 2, 1, 0, 1],  # M shape
            10: [0, 1, 1, 1, 2],  # Step down
            11: [2, 1, 1, 1, 0],  # Step up
            12: [0, 1, 0, 1, 2],  # Zigzag down
            13: [2, 1, 2, 1, 0],  # Zigzag up
            14: [1, 1, 0, 1, 1],  # Dip center
            15: [1, 1, 2, 1, 1],  # Peak center
            16: [0, 2, 1, 0, 2],  # Butterfly
            17: [2, 0, 1, 2, 0],  # Inverted butterfly
            18: [0, 0, 2, 0, 0],  # Top corners
            19: [2, 2, 0, 2, 2],  # Bottom corners
            20: [1, 0, 0, 0, 1],  # U shape
        }

        self.include_padding = True
        self.special_symbols = {"wild": ["W"], "scatter": ["S"]}

        # Free Spin Triggers
        # EXTREME TEST: Massive free spins to achieve 96% RTP
        # Base game: 2/3/4/5 scatters → 20/30/50/80 free spins
        # Free game retrigger: 3/4/5 scatters → 10/20/40 additional spins
        self.freespin_triggers = {
            self.basegame_type: {2: 20, 3: 30, 4: 50, 5: 80},
            self.freegame_type: {3: 10, 4: 20, 5: 40},
        }
        self.anticipation_triggers = {
            self.basegame_type: min(self.freespin_triggers[self.basegame_type].keys()) - 1,
            self.freegame_type: min(self.freespin_triggers[self.freegame_type].keys()) - 1,
        }
        
        # Reels
        reels = {"BR0": "BR0.csv", "FR0": "FR0.csv"}
        self.reels = {}
        for r, f in reels.items():
            self.reels[r] = self.read_reels_csv(os.path.join(self.reels_path, f))

        self.padding_reels[self.basegame_type] = self.reels["BR0"]
        self.padding_reels[self.freegame_type] = self.reels["FR0"]

        # Distribution Conditions
        freegame_condition = {
            "reel_weights": {
                self.basegame_type: {"BR0": 1},
                self.freegame_type: {"FR0": 1},
            },
            "scatter_triggers": {3: 50, 4: 20, 5: 5},  # Weight 3 scatters highest
            "force_wincap": False,
            "force_freegame": True,  # Always trigger free spins for this distribution
        }

        basegame_condition = {
            "reel_weights": {self.basegame_type: {"BR0": 1}},
            "force_wincap": False,
            "force_freegame": False,
        }

        wincap_condition = {
            "reel_weights": {
                self.basegame_type: {"BR0": 1},
                self.freegame_type: {"FR0": 1},
            },
            "scatter_triggers": {4: 1, 5: 2},  # More spins for wincap scenarios
            "force_wincap": True,   # Force exactly 5000x win
            "force_freegame": True,
        }

        zerowin_condition = {
            "reel_weights": {self.basegame_type: {"BR0": 1}},
            "force_wincap": False,
            "force_freegame": False,
        }

        mode_maxwins = {"base": 5000}
        
        # Contains all game-logic simulation conditions
        self.bet_modes = [
            BetMode(
                name="base",
                cost=1.0,
                rtp=self.rtp,
                max_win=mode_maxwins["base"],
                auto_close_disabled=False,
                is_feature=True,
                is_buybonus=False,
                distributions=[
                    # Wincap disabled for initial test (hard to achieve with small reel strips)
                    # Distribution(
                    #     criteria="wincap",
                    #     quota=0.001,
                    #     win_criteria=mode_maxwins["base"],
                    #     conditions=wincap_condition,
                    # ),
                    # Free game: 8% of spins trigger free spins
                    Distribution(
                        criteria="freegame",
                        quota=0.08,
                        conditions=freegame_condition,
                    ),
                    # Zero win: 71.5% of spins = no win (high volatility)
                    Distribution(
                        criteria="0",
                        quota=0.715,
                        win_criteria=0.0,
                        conditions=zerowin_condition,
                    ),
                    # Base game: 20.5% of spins = regular wins (increased from 18.5%)
                    Distribution(
                        criteria="basegame",
                        quota=0.205,
                        conditions=basegame_condition,
                    ),
                ],
            ),
        ]
